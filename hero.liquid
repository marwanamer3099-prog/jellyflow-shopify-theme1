<div class="hero">
  <div class="hero-glow"></div>
  <span class="jelly-anim">🪼</span>
  <p class="hero-tag">{{ section.settings.tag }}</p>
  <h1 class="hero-h1">It <span class="grd">Floats. It Glows.</span> It's Hypnotic.</h1>
  <p class="hero-sub">{{ section.settings.subtext }}</p>
  <a href="#bundle-sec" class="hero-cta">{{ section.settings.cta_text }}</a>
  <div class="hero-badges">
    <span class="hb">🚚 Free Shipping</span>
    <span class="hb">⭐ 4.9/5 Stars</span>
    <span class="hb">🔄 30-Day Returns</span>
    <span class="hb">🔒 Secure Checkout</span>
  </div>
  <div class="live-bar">
    <div class="live-dot"></div>
    <span><span id="live-count">43</span> people viewing this right now</span>
  </div>
</div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {"type":"text","id":"tag","label":"Tag Line","default":"The Internet's Favourite Mood Lamp"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"The Levitating LED Jellyfish Lamp — over 10,000 people already own one."},
    {"type":"text","id":"cta_text","label":"Button Text","default":"Shop Now — 50% Off Today"}
  ]
}
{% endschema %}
